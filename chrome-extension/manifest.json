{
  "manifest_version": 3,
  "name": "Nest Cookies & Token Extractor",
  "version": "1.0",
  "description": "Extracts issue_token and cookies from home.nest.com for Home Assistant Nest Protect integration.",
  "permissions": [
    "webRequest",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://home.nest.com/*",
    "https://accounts.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
